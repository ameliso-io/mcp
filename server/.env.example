# Required — numeric GitHub App ID from the app settings page
GITHUB_APP_ID=123456

# Required — PEM-encoded RSA private key (paste inline or use a file path trick below)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_KEY_HERE
-----END RSA PRIVATE KEY-----"

# Required — slug of your GitHub App (visible in the app's URL on GitHub)
GITHUB_APP_NAME=your-app-name

# Optional — override the full installation URL (takes precedence over GITHUB_APP_NAME)
# GITHUB_APP_INSTALLATION_URL=https://github.com/apps/your-app-name/installations/new

# Optional — server port (default: 50052)
# AMELISO_PORT=50052

# Optional — override where repos and metadata are stored (default: ~/.ameliso)
# AMELISO_DATA_DIR=/tmp/ameliso-dev
