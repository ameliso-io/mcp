#!/usr/bin/env bash
# Warn on push if any test cases have never been run or are failing.

set -euo pipefail

output=$(python3 report.py --summary 2>&1)
echo "$output"

if echo "$output" | grep -qE "^(FAILED|never run|blocked):"; then
  echo "Warning: some test cases are failing, blocked, or have never been run."
  echo "Run 'python3 report.py' for details."
  # Warn only — do not block push. Remove 'exit 0' to enforce.
  exit 0
fi
