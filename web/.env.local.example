# Server-side only: URL of the Ameliso gRPC-Web server for the Next.js rewrite proxy.
# Defaults to http://localhost:50052. Set this to the internal service URL in production.
# Never exposed to the browser bundle.
API_URL=

# Public base URL of the deployed site (e.g. https://ameliso.example.com).
# Used in sitemap.xml and og:url metadata. If unset, defaults to http://localhost:3000.
SITE_URL=
