{
  "name": "ameliso-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 5173",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:typecheck": "tsc --project tsconfig.test.json --noEmit",
    "test:coverage": "vitest run --coverage",
