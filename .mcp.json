{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp", "--isolated"]
    },
    "centy": {
      "args": [
        "-y",
        "centy-mcp"
      ],
      "command": "npx"
    },
    "ameliso": {
      "command": "cargo",
      "args": ["run", "--quiet", "--package", "ameliso-mcp", "--"]
    }
  }
}
