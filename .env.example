# Required — server will refuse to start without these
DATABASE_URL=postgres://ameliso:ameliso@localhost:5432/ameliso
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Optional — GitHub App UI settings (used in installation flow)
GITHUB_APP_NAME=ameliso
GITHUB_APP_INSTALLATION_URL=https://github.com/apps/ameliso/installations/new
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Optional — server ports (defaults shown)
AMELISO_PORT=50052
AMELISO_WEBHOOK_PORT=8080

# Optional — database connection pool size (default: 10)
AMELISO_DB_POOL_SIZE=10

# Optional — URL of the web UI (used in GitHub check run links)
AMELISO_UI_URL=http://localhost:3000

# Optional — override GitHub API base URL (for testing against a mock server)
AMELISO_GITHUB_API=https://api.github.com

# Optional — set to json for structured log output (default: text)
AMELISO_LOG_FORMAT=text

# Optional — enable dev mode (auto-kills ports on startup, disables some checks)
AMELISO_DEV=false
