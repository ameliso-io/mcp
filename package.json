{
  "name": "ameliso",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter ameliso-web build",
    "dev": "concurrently --names \"grpc,web\" --prefix-colors \"blue,green\" \"cargo run -p ameliso-server\" \"pnpm --filter ameliso-web dev\""
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cspell": "^8.17.3",
    "husky": "^9.1.7"
  }
}
